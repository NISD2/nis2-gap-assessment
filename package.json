{
  "name": "@nisd2/nis2-gap-assessment-schema",
  "version": "2.0.0",
  "description": "Open NIS2 gap assessment — 116 questions across 15 domains, with legal citations to NIS2, BSIG, CIR 2024/2690, and IT-Grundschutz. Zod schema as source of truth, TypeScript types, reference scoring logic.",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/NISD2/nis2-gap-assessment-schema",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NISD2/nis2-gap-assessment-schema.git"
  },
  "bugs": {
    "url": "https://github.com/NISD2/nis2-gap-assessment-schema/issues"
  },
  "author": "Kardashev Catalyst UG (haftungsbeschränkt) <contact@nisd2.eu> (https://nisd2.eu)",
  "keywords": [
    "nis2",
    "bsig",
    "cir-2024-2690",
    "it-grundschutz",
    "compliance",
    "cybersecurity",
    "gap-assessment",
    "zod"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    },
    "./scoring": {
      "types": "./dist/scoring.d.ts",
      "import": "./dist/scoring.js"
    },
    "./data": {
      "types": "./dist/data.d.ts",
      "import": "./dist/data.js"
    },
    "./data/gap-assessment.json": "./data/gap-assessment.json",
    "./schema/gap-assessment.schema.json": "./schema/gap-assessment.schema.json"
  },
  "files": [
    "dist",
    "data",
    "schema",
    "src",
    "examples",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc --noEmit -p tsconfig.examples.json",
    "test": "bun test",
    "build:json": "bun scripts/build-json.ts",
    "validate": "bun src/data.ts && echo 'OK: TS source validates against schema'",
    "check:json-in-sync": "bun scripts/build-json.ts && git diff --exit-code data/gap-assessment.json schema/gap-assessment.schema.json"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "drizzle-orm": "^0.45.2",
    "typescript": "^5.7.3",
    "zod-to-json-schema": "^3.25.2"
  }
}
